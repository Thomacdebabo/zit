#!/usr/bin/env bash

# zit - Zimple Interval Tracker (Bash implementation)

set -euo pipefail

ZIT_DIR="${HOME}/.zit"
DEFAULT_TASK="DEFAULT"

forward_to_python_zit() {
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local python_zit="${script_dir}/zit-python"
    
    if [[ -x "$python_zit" ]]; then
        "$python_zit" "$@"
    else
        echo "Error: zit-python not found in ${script_dir}" >&2
        echo "Please install zit-python in the same directory as this script" >&2
        return 1
    fi
}

ensure_zit_dir() {
    mkdir -p "${ZIT_DIR}"
}

get_timestamp() {
    date +"%Y-%m-%d %H:%M:%S.%6N"
}

get_today() {
    date +%Y-%m-%d
}

get_yesterday() {
    date -d "yesterday" +%Y-%m-%d
}

parse_date_args() {
    local use_yesterday=false
    local custom_date=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--yesterday)
                use_yesterday=true
                shift
                ;;
            -d|--date)
                custom_date="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
    
    if [[ -n "${custom_date}" ]]; then
        if ! date -d "${custom_date}" +%Y-%m-%d &>/dev/null; then
            echo "Error: Invalid date format. Use YYYY-MM-DD" >&2
            return 1
        fi
        echo "${custom_date}"
    elif [[ "${use_yesterday}" == true ]]; then
        get_yesterday
    else
        get_today
    fi
}

get_project_file() {
    local day="${1:-$(get_today)}"
    echo "${ZIT_DIR}/${day}.csv"
}

get_subtask_file() {
    local day="${1:-$(get_today)}"
    echo "${ZIT_DIR}/${day}_subtasks.csv"
}

get_current_task() {
    local day="${1:-$(get_today)}"
    local project_file=$(get_project_file "${day}")
    
    if [[ ! -f "${project_file}" ]]; then
        echo ""
        return
    fi
    
    local last_line=$(tail -n 1 "${project_file}")
    local last_project=$(echo "${last_line}" | cut -d',' -f2)
    
    if [[ "${last_project}" == "STOP" || "${last_project}" == "LUNCH" ]]; then
        echo ""
    else
        echo "${last_project}"
    fi
}

parse_time() {
    local time="$1"
    local day="${2:-$(get_today)}"
    
    if ! [[ "${time}" =~ ^[0-9]+$ ]]; then
        echo "Error: Time must be in HHMM format (e.g., 1200 for noon)" >&2
        return 1
    fi
    
    if [[ ${#time} -eq 1 ]]; then
        time="0${time}00"
    elif [[ ${#time} -eq 2 ]]; then
        time="${time}00"
    elif [[ ${#time} -eq 3 ]]; then
        time="0${time}"
    fi
    
    local hour="${time:0:2}"
    local minute="${time:2:2}"
    
    hour=$((10#$hour))
    minute=$((10#$minute))
    
    if [[ ${hour} -lt 0 || ${hour} -gt 23 || ${minute} -lt 0 || ${minute} -gt 59 ]]; then
        echo "Error: Invalid time values" >&2
        return 1
    fi
    
    hour=$(printf "%02d" ${hour})
    minute=$(printf "%02d" ${minute})
    
    echo "${day} ${hour}:${minute}:00.000000"
}

resolve_timestamp() {
    local time="$1"
    local day="$2"

    if [[ -n "${time}" ]]; then
        parse_time "${time}" "${day}"
    else
        get_timestamp
    fi
}

format_display_time() {
    local timestamp="$1"
    echo "${timestamp}" | cut -d' ' -f2 | cut -d':' -f1,2
}

cmd_start() {
    local project="${1:-${DEFAULT_TASK}}"
    local subtask=""
    local note=""
    local time=""
    
    shift || true
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sub|-s)
                subtask="$2"
                shift 2
                ;;
            --note|-n)
                note="$2"
                shift 2
                ;;
            --time|-t)
                time="$2"
                shift 2
                ;;
            -y|--yesterday|-d|--date)
                shift
                [[ $# -gt 0 && "$1" != "-"* ]] && shift || true
                ;;
            *)
                shift
                ;;
        esac
    done
    
    ensure_zit_dir
        local timestamp
        timestamp=$(resolve_timestamp "${time}" "${day}") || return 1
    local project_file=$(get_project_file "${day}")
    local subtask_file=$(get_subtask_file "${day}")
    
    if [[ -n "${subtask}" ]]; then
        local current=$(get_current_task "${day}")
        if [[ -z "${current}" ]]; then
            echo "${timestamp},${DEFAULT_TASK}" >> "${project_file}"
        fi
        echo "${timestamp},${subtask},${note}" >> "${subtask_file}"
        echo "Started tracking time for subtask: ${subtask}"
    else
        echo "${timestamp},${project}" >> "${project_file}"
        if [[ -n "${note}" ]]; then
            echo "${timestamp},${project}-sub,${note}" >> "${subtask_file}"
        fi
        echo "Started tracking time for project: ${project}"
    fi
}

cmd_stop() {
    local day
    day=$(parse_date_args "$@") || return 1
    
    ensure_zit_dir
    local timestamp=$(get_timestamp)
    local project_file=$(get_project_file "${day}")
    
    echo "${timestamp},STOP" >> "${project_file}"
    echo "Stopped time tracking"
}

cmd_lunch() {
    local time=""
    
    if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
        time="$1"
        shift
    fi
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    ensure_zit_dir
    local project_file=$(get_project_file "${day}")
    local timestamp
    timestamp=$(resolve_timestamp "${time}" "${day}") || return 1
    
    echo "${timestamp},LUNCH" >> "${project_file}"
    echo "Started lunch time tracking"
}

cmd_add() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: zit add PROJECT TIME [--sub SUBTASK] [--note NOTE] [-y|--yesterday] [-d|--date DATE]" >&2
        return 1
    fi
    
    local project="$1"
    local time="$2"
    local subtask=""
    local note=""
    
    shift 2
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sub|-s)
                subtask="$2"
                shift 2
                ;;
            --note|-n)
                note="$2"
                shift 2
                ;;
            -y|--yesterday|-d|--date)
                shift
                [[ $# -gt 0 && "$1" != "-"* ]] && shift || true
                ;;
            *)
                shift
                ;;
        esac
    done
    
    ensure_zit_dir
    local timestamp
    timestamp=$(parse_time "${time}" "${day}") || return 1
    local project_file=$(get_project_file "${day}")
    local subtask_file=$(get_subtask_file "${day}")
    
    if [[ -n "${subtask}" ]]; then
        echo "${timestamp},${subtask},${note}" >> "${subtask_file}"
        local display_time
        display_time=$(format_display_time "${timestamp}")
        echo "Added subtask: ${subtask} at ${display_time}"
    else
        echo "${timestamp},${project}" >> "${project_file}"
        local display_time
        display_time=$(format_display_time "${timestamp}")
        echo "Added project: ${project} at ${display_time}"
    fi
}

cmd_sub() {
    local subtask="${1:-${DEFAULT_TASK}}"
    local note=""
    
    shift || true
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --note|-n)
                note="$2"
                shift 2
                ;;
            -y|--yesterday|-d|--date)
                shift
                [[ $# -gt 0 && "$1" != "-"* ]] && shift || true
                ;;
            *)
                shift
                ;;
        esac
    done
    
    ensure_zit_dir
    local current=$(get_current_task "${day}")
    
    if [[ -z "${current}" ]]; then
        echo "No current task. Operation aborted." >&2
        return 1
    fi
    
    local timestamp=$(get_timestamp)
    local subtask_file=$(get_subtask_file "${day}")
    
    echo "${timestamp},${subtask},${note}" >> "${subtask_file}"
    echo "Added subtask: ${subtask}"
}

cmd_current() {
    local day
    day=$(parse_date_args "$@") || return 1
    
    local current=$(get_current_task "${day}")
    
    if [[ -z "${current}" ]]; then
        echo "No current task."
    else
        echo "Current task: ${current}"
    fi
}

cmd_remove() {
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    local project_file=$(get_project_file "${day}")
    local subtask_file=$(get_subtask_file "${day}")
    
    local has_projects=false
    local has_subtasks=false
    
    if [[ -f "${project_file}" && -s "${project_file}" ]]; then
        has_projects=true
    fi
    
    if [[ -f "${subtask_file}" && -s "${subtask_file}" ]]; then
        has_subtasks=true
    fi
    
    if [[ "${has_projects}" == false && "${has_subtasks}" == false ]]; then
        echo "No events found for ${day}. Operation aborted." >&2
        return 1
    fi
    
    if ! command -v fzf &> /dev/null; then
        echo "Error: fzf is not installed. Please install fzf to use this command." >&2
        echo "Install with: sudo apt install fzf  (or brew install fzf on macOS)" >&2
        return 1
    fi
    
    local combined_list=""
    local temp_list=$(mktemp)
    
    if [[ "${has_projects}" == true ]]; then
        cat -n "${project_file}" | sed 's/^[ \t]*//' | awk -F'\t' '{
            split($2, parts, ",");
            timestamp = parts[1];
            name = parts[2];
            split(timestamp, dt, " ");
            split(dt[2], time, ":");
            printf "%s|[P:%d] %s:%s - %s\n", timestamp, $1, time[1], time[2], name;
        }' >> "${temp_list}"
    fi
    
    if [[ "${has_subtasks}" == true ]]; then
        cat -n "${subtask_file}" | sed 's/^[ \t]*//' | awk -F'\t' '{
            split($2, parts, ",");
            timestamp = parts[1];
            name = parts[2];
            note = parts[3];
            split(timestamp, dt, " ");
            split(dt[2], time, ":");
            printf "%s|  [S:%d] %s:%s - %s", timestamp, $1, time[1], time[2], name;
            if (note != "") printf " (%s)", note;
            printf "\n";
        }' >> "${temp_list}"
    fi
    
    combined_list=$(sort -t'|' -k1,1 "${temp_list}" | cut -d'|' -f2-)
    rm -f "${temp_list}"
    
    local selection=$(echo "${combined_list}" | fzf --prompt="Select event to remove (P=project, S=subtask): " --height=40% --reverse --ansi)
    
    if [[ -z "${selection}" ]]; then
        echo "No selection made. Operation aborted."
        return 0
    fi
    
    selection=$(echo "${selection}" | sed 's/^[[:space:]]*//')
    local type_prefix=$(echo "${selection}" | sed 's/\[//' | cut -d':' -f1)
    local line_num=$(echo "${selection}" | sed 's/\[//' | cut -d':' -f2 | cut -d']' -f1)

    if [[ "${type_prefix}" == "P" ]]; then
        local file="${project_file}"
        local type="project"
        
        local project_line=$(sed -n "${line_num}p" "${file}")
        local timestamp=$(echo "${project_line}" | cut -d',' -f1)
        local project_name=$(echo "${project_line}" | cut -d',' -f2-)
        
        local next_line=$((line_num + 1))
        local next_timestamp=$(sed -n "${next_line}p" "${file}" | cut -d',' -f1)
        
        if [[ -f "${subtask_file}" && -s "${subtask_file}" ]]; then
            local orphaned_subtasks=""
            
            if [[ -n "${next_timestamp}" ]]; then
                orphaned_subtasks=$(awk -F',' -v ts="${timestamp}" -v next_ts="${next_timestamp}" '
                    $1 > ts && $1 < next_ts { print; found=1 }
                    END { if (!found) exit 1 }
                ' "${subtask_file}" 2>/dev/null || true)
            else
                orphaned_subtasks=$(awk -F',' -v ts="${timestamp}" '
                    $1 > ts { print; found=1 }
                    END { if (!found) exit 1 }
                ' "${subtask_file}" 2>/dev/null || true)
            fi
            
            if [[ -n "${orphaned_subtasks}" ]]; then
                local first_subtask_ts=$(echo "${orphaned_subtasks}" | head -1 | cut -d',' -f1)
                echo "Orphaned subtasks detected. Creating new project entry at ${first_subtask_ts}"
                echo "${first_subtask_ts},${project_name}" >> "${file}"
                sort -t',' -k1,1 "${file}" -o "${file}"
            fi
            
            local matching_count=$(grep -c "^${timestamp}," "${subtask_file}" 2>/dev/null || true)
            matching_count=${matching_count:-0}
            
            if [[ ${matching_count} -gt 0 ]]; then
                echo "Found ${matching_count} subtask(s) with the same timestamp."
                sed -i "/^${timestamp},/d" "${subtask_file}"
                echo "Removed ${matching_count} related subtask(s)."
            fi
        fi
    else
        local file="${subtask_file}"
        local type="subtask"
    fi
    
    sed -i "${line_num}d" "${file}"
    echo "${type^} has been removed."
}

cmd_ted_start() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: zit ted-start PROJECT [--sub SUBTASK] [--note NOTE] [--time|-t TIME] [-y|--yesterday] [-d|--date DATE]" >&2
        return 1
    fi
    
    local project="$1"
    local subtask=""
    local note=""
    local time=""
    
    shift
    
    local day
    day=$(parse_date_args "$@") || return 1
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sub|-s)
                subtask="$2"
                shift 2
                ;;
            --note|-n)
                note="$2"
                shift 2
                ;;
            --time|-t)
                time="$2"
                shift 2
                ;;
            -y|--yesterday|-d|--date)
                shift
                [[ $# -gt 0 && "$1" != "-"* ]] && shift || true
                ;;
            *)
                shift
                ;;
        esac
    done
    
    ensure_zit_dir
        local timestamp
        timestamp=$(resolve_timestamp "${time}" "${day}") || return 1
    local project_file=$(get_project_file "${day}")
    local subtask_file=$(get_subtask_file "${day}")

    echo "${timestamp},${project}" >> "${project_file}"
    
    if [[ -n "${subtask}" ]]; then
        echo "${timestamp},${subtask},${note}" >> "${subtask_file}"
    fi
    
        local display_time
        display_time=$(format_display_time "${timestamp}")
    
    if [[ -n "${subtask}" ]]; then
        echo "Started tracking time for project: ${project}, subtask: ${subtask}, at ${display_time}"
    else
        echo "Started tracking time for project: ${project}, subtask: N/A, at ${display_time}"
    fi
}

main() {
    if [[ $# -eq 0 ]]; then
        echo "zit - Zimple Interval Tracker"
        echo ""
        echo "Usage: zit COMMAND [OPTIONS]"
        echo ""
        echo "Bash-implemented commands:"
        echo "  start [PROJECT]           Start tracking a project"
        echo "    --sub SUBTASK           Start tracking a subtask"
        echo "    --note NOTE             Add a note"
        echo "    --time TIME, -t TIME    Start at specific time (HHMM format)"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  stop                      Stop tracking time"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  lunch [TIME]              Start lunch break"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  add PROJECT TIME          Add a project at specific time (HHMM)"
        echo "    --sub SUBTASK           Add as subtask instead"
        echo "    --note NOTE             Add a note"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  sub SUBTASK               Add a subtask to current project"
        echo "    --note NOTE             Add a note"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  current                   Show current task"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  remove, rm                Remove an event (uses fzf)"
        echo "    -s, --sub, --subtask    Remove a subtask instead"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo "  ted-start PROJECT         Start project with optional subtask"
        echo "    --sub SUBTASK           Add a subtask"
        echo "    --note NOTE             Add a note"
        echo "    --time TIME, -t TIME    Start at specific time (HHMM format)"
        echo "    -y, --yesterday         Use yesterday's date"
        echo "    -d, --date DATE         Use specific date (YYYY-MM-DD)"
        echo ""
        echo "Python-forwarded commands:"
        echo "  status                    Show today's status (with time calculations)"
        echo "  clean                     Clean and organize entries"
        echo "  verify                    Verify data integrity"
        echo "  remove                    Remove an event"
        echo "  change                    Change an event"
        echo "  list                      List all subtasks"
        echo "  note                      Add note to subtask"
        echo ""
        echo "Run 'zit <command> --help' for more information on each command"
        return 0
    fi
    
    local command="$1"
    shift
    
    case "${command}" in
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        lunch)
            cmd_lunch "$@"
            ;;
        add)
            cmd_add "$@"
            ;;
        sub)
            cmd_sub "$@"
            ;;
        remove|rm)
            cmd_remove "$@"
            ;;
        ted-start)
            cmd_ted_start "$@"
            ;;
        status|clean|verify|change|list|note|attach)
            forward_to_python_zit "${command}" "$@"
            ;;
        *)
            echo "Unknown command: ${command}" >&2
            echo "Run 'zit' without arguments to see usage." >&2
            return 1
            ;;
    esac
}

main "$@"
